# Pinky Configuration
# Copy to pinky.yaml and fill in your values

# Memory system
memory:
  db_path: ./data/memory.db
  embedding_model: text-embedding-3-small
  embedding_provider: openai  # or "local" for offline embeddings
  vector_dimensions: 1536
  search_top_k: 10

  # Memory lifecycle tuning
  decay_factor: 0.97                # Daily weight decay (~23-day half-life)
  decay_immunity_salience: 4        # Salience >= this is immune to decay
  consolidation_threshold: 0.85     # Cosine similarity for auto-merge
  promotion_min_cluster_size: 3     # Min cluster size for episodic -> semantic

# Outreach (messaging platforms)
outreach:
  telegram:
    bot_token: ${TELEGRAM_BOT_TOKEN}
    mode: polling  # or "webhook"
    # webhook_url: https://your-domain.com/webhook
    # webhook_secret: ${TELEGRAM_WEBHOOK_SECRET}

  # discord:
  #   bot_token: ${DISCORD_BOT_TOKEN}
  #   allowed_channel_ids: []

  # slack:
  #   bot_token: ${SLACK_BOT_TOKEN}

# Google services
# google:
